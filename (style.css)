body {
  font-family: 'Arial', sans-serif;
  background-color: #F5F0E1; /* بيج فاتح */
  text-align: center;
  padding: 20px;
}

button {
  padding: 10px 20px;
  margin: 10px;
  cursor: pointer;
  border: none;
  border-radius: 10px;
  font-size: 16px;
}

#progressBar {
  width: 80%;
  height: 15px;
  background-color: #ddd;
  margin: 20px auto;
  border-radius: 10px;
}

#progress {
  width: 0%;
  height: 100%;
  background-color: #FFA500; /* لون الجيل الأول */
  border-radius: 10px;
}
