// ===== بيانات تجريبية للأسئلة =====
const quizData = [
  { question: "السؤال 1", options: ["أ", "ب", "ج"], answer: 0 },
  { question: "السؤال 2", options: ["أ", "ب", "ج"], answer: 1 },
  { question: "السؤال 3", options: ["أ", "ب", "ج"], answer: 2 },
  { question: "السؤال 4", options: ["أ", "ب", "ج"], answer: 0 },
  { question: "السؤال 5", options: ["أ", "ب", "ج"], answer: 1 },
  { question: "السؤال 6", options: ["أ", "ب", "ج"], answer: 2 },
  { question: "السؤال 7", options: ["أ", "ب", "ج"], answer: 0 },
  { question: "السؤال 8", options: ["أ", "ب", "ج"], answer: 1 },
  { question: "السؤال 9", options: ["أ", "ب", "ج"], answer: 2 },
];

const generations = ["جيل الأحفاد", "جيل الآباء", "جيل الأجداد"];
const generationColors = ["#FFA500", "#00A86B", "#800000"]; // برتقالي، أخضر، عنابي

let username = "";
let currentGen = 0;
let currentQuestion = 0;
let score = 0;

// ===== التسجيل =====
document.getElementById("startBtn").addEventListener("click", () => {
  const input = document.getElementById("username").value.trim();
  if(input === "") { alert("أدخل اسمك أولاً 😄"); return; }
  username = input;
  document.getElementById("registerPage").style.display = "none";
  showGenerationTransition();
});

// ===== صفحة الانتقال =====
function showGenerationTransition() {
  document.getElementById("generationTitle").innerText = generations[currentGen];
  document.getElementById("quizPage").style.display = "block";
  document.getElementById("generationTransition").style.display = "block";
  document.getElementById("questionContainer").style.display = "none";
  document.getElementById("progress").style.backgroundColor = generationColors[currentGen];
}

document.getElementById("startGenBtn").addEventListener("click", () => {
  document.getElementById("generationTransition").style.display = "none";
  document.getElementById("questionContainer").style.display = "block";
  loadQuestion();
});

// ===== تحميل السؤال =====
function loadQuestion() {
  const q = quizData[currentQuestion];
  document.getElementById("questionText").innerText = q.question;
  const options = document.querySelectorAll(".optionBtn");
  options.forEach((btn, index) => {
    btn.innerText = q.options[index];
    btn.style.backgroundColor = "#eee";
    btn.onclick = () => selectOption(index, btn);
  });

  // تحديث شريط التقدم
  const progressPercent = (currentQuestion / quizData.length) * 100;
  document.getElementById("progress").style.width = progressPercent + "%";
}

let selectedOption = null;
function selectOption(index, btn) {
  selectedOption = index;
  document.querySelectorAll(".optionBtn").forEach(b => b.style.backgroundColor="#eee");
  btn.style.backgroundColor = "#ADD8E6";
}

// ===== زر التالي =====
document.getElementById("nextBtn").addEventListener("click", () => {
  if(selectedOption === null) { alert("اختار إجابة أولاً 😄"); return; }

  if(selectedOption === quizData[currentQuestion].answer) score++;

  selectedOption = null;
  currentQuestion++;

  // تغيير الجيل كل 3 أسئلة
  if(currentQuestion % 3 === 0 && currentQuestion < quizData.length) {
    currentGen++;
    showGenerationTransition();
  } else if(currentQuestion >= quizData.length) {
    showResult();
  } else {
    loadQuestion();
  }
});

// ===== النتائج =====
function showResult() {
  document.getElementById("quizPage").style.display = "none";
  document.getElementById("resultPage").style.display = "block";

  let title = "";
  if(score <= 2) title = "مخ دامنو";
  else if(score <= 5) title = "الطاهر برو";
  else if(score <= 7) title = "أوقج مني";
  else title = "درار الكبير";

  document.getElementById("resultText").innerText = `${username}، حصلت على ${score} نقطة.`;
  document.getElementById("titleText").innerText = `لقبك: ${title}`;

  // حفظ البيانات في LocalStorage (محلي)
  const existingData = JSON.parse(localStorage.getItem("quizData") || "[]");
  existingData.push({ name: username, score: score, title: title });
  localStorage.setItem("quizData", JSON.stringify(existingData));
}
